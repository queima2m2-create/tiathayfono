# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Use only npm (package-lock.json) — avoid multi-package-manager conflicts
# that break hosted builds (DigitalOcean App Platform rejects the repo
# otherwise). Lovable regenerates bun.lock locally as needed.
bun.lock
bun.lockb

# Environment variables — DO NOT commit real secrets here.
# (.env is tracked because it only contains public Supabase publishable keys
# that Lovable/Vite need at build time. Never add secret keys to .env.)
.env.local
.env.*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
